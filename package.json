{
  "name": "ranni-mcp",
  "version": "0.1.0",
  "description": "Provider-agnostic multi-agent orchestration MCP server",
  "type": "module",
  "files": [
    "bin",
    "src",
    "templates"
  ],
  "bin": {
    "ranni-mcp": "./bin/ranni-mcp.js"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "init": "bun run src/init.ts",
    "build": "bun build --compile src/index.ts --outfile dist/ranni-mcp",
    "typecheck": "tsc --noEmit",
    "release": "bun run scripts/publish.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  }
}
